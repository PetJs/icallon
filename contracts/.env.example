# Copy this to .env and fill in your values
# NEVER commit .env to git

# Wallet that pays deployment gas and optionally funds the prize pool
DEPLOYER_PRIVATE_KEY=0xe4EC2Aeda651e22945b45b2cBcaaF3cE2EB5EF90

# Address that will call startRound(), openReveal(), openFlagging(), scoreRound()
# Can be the same as the deployer wallet
ADMIN_ADDRESS=0xe4EC2Aeda651e22945b45b2cBcaaF3cE2EB5EF90

# Prize pool in wei — default is 1 MON (1000000000000000000)
# Players win this at the end of the tournament
INITIAL_PRIZE_POOL=1000000000000000000

# Optional: Monad explorer API key for contract verification
MONAD_EXPLORER_KEY=
